# Solar Assistant Docker Environment Variables
# Copy this file to .env and customize for your setup

# Timezone
TZ=UTC

# MQTT Settings
MQTT_ENABLED=true
MQTT_USERNAME=
MQTT_PASSWORD=

# InfluxDB Settings
INFLUXDB_ENABLED=true
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=solarpassword123
INFLUXDB_ORG=solar-assistant
INFLUXDB_BUCKET=solar-data
INFLUXDB_TOKEN=solar-assistant-token

# Redis Settings
REDIS_PASSWORD=

# Application Settings
FLASK_ENV=production
SECRET_KEY=change-this-to-a-random-string

# Email Settings (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=